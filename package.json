{
  "name": "agri-waste-backend",
  "version": "1.0.0",
  "description": "Simple SQLite backend for agricultural waste recycling demo",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "init": "node server.js --init",
    "test:p0": "node tests/api_tests/test-p0-guardrails.js",
    "test:p1": "node tests/api_tests/test-p1-traceability.js",
    "test:p2": "node tests/api_tests/test-p2-mock-cleanup.js",
    "test:p3": "node tests/api_tests/test-p3-authz-negative.js",
    "test:p4": "node tests/api_tests/test-p4-failure-paths.js",
    "test:p5": "node tests/api_tests/test-p5-observability-alert-drill.js",
    "test:p6": "node tests/api_tests/test-p6-release-drill.js",
    "test:p7": "node tests/api_tests/test-p7-gray-rollback-drill.js",
    "test:p8": "node tests/api_tests/test-p8-processor-request-lifecycle.js",
    "test:p9": "node tests/api_tests/test-p9-auth-trust-boundary.js",
    "test:p10": "node tests/api_tests/test-p10-sms-runtime-guard.js",
    "test:p11": "node tests/api_tests/test-p11-login-readiness.js",
    "test:release-drill": "npm run test:p6",
    "test:gray-drill": "npm run test:p7",
    "test:processor-lifecycle": "node tests/api_tests/run-p8-processor-lifecycle.js",
    "test:auth-boundary": "npm run test:p9",
    "test:sms-runtime": "npm run test:p10",
    "test:login-readiness": "npm run test:p11",
    "test:gates": "node tests/api_tests/run-step3-b2-gates.js",
    "dev:h5": "uni",
    "dev:mp-weixin": "uni -p mp-weixin",
    "build:h5": "uni build",
    "build:mp-weixin": "uni build -p mp-weixin"
  },
  "dependencies": {
    "@alicloud/dysmsapi20170525": "^4.5.1",
    "@alicloud/openapi-client": "^0.4.15",
    "@alicloud/tea-util": "^1.4.11",
    "@dcloudio/uni-app": "3.0.0-3081220230817001",
    "@dcloudio/uni-components": "3.0.0-3081220230817001",
    "@dcloudio/uni-mp-weixin": "3.0.0-3081220230817001",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.6",
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@dcloudio/vite-plugin-uni": "3.0.0-3081220230817001",
    "vite": "^4.4.9"
  }
}
