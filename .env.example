# Server Configuration
NODE_ENV=development
PORT=4000

# Database
DB_PATH=./data/agri.db

# Security - JWT
# Generate a strong random key: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:4000,http://localhost:3000

# Aliyun SMS Configuration (when implementing real SMS)
ALIYUN_ACCESS_KEY_ID=your_aliyun_access_key
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_access_secret
ALIYUN_SMS_SIGN=your_sms_sign_name
ALIYUN_SMS_TEMPLATE=your_otp_template_id

# File Upload Settings
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Bcrypt Configuration
BCRYPT_ROUNDS=10
