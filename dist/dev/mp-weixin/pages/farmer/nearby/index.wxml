<view class="container data-v-08110e48"><view class="header data-v-08110e48"><text class="title data-v-08110e48">附近的柑橘果肉回收点</text><text class="desc data-v-08110e48">展示已公开地址的回收商与处理商</text></view><map class="map-area data-v-08110e48" latitude="{{a}}" longitude="{{b}}" markers="{{c}}" scale="12"></map><view class="list-container data-v-08110e48"><view wx:for="{{d}}" wx:for-item="item" wx:key="g" class="recycler-card data-v-08110e48"><view class="info data-v-08110e48"><view class="name-row data-v-08110e48"><text class="name data-v-08110e48">{{item.a}}</text><text class="{{['role-badge', 'data-v-08110e48', item.c]}}">{{item.b}}</text></view><text class="address data-v-08110e48">{{item.d}}</text><text class="phone-text data-v-08110e48">📞 {{item.e}}</text></view><button class="intention-btn data-v-08110e48" size="mini" bindtap="{{item.f}}">发起意向</button></view><view wx:if="{{e}}" class="empty-state data-v-08110e48"><text class="empty-icon data-v-08110e48">📍</text><text class="empty-text data-v-08110e48">暂无公开的回收/处理点</text></view></view><view wx:if="{{f}}" class="popup-mask data-v-08110e48" bindtap="{{g}}"></view><view wx:if="{{h}}" class="intention-popup data-v-08110e48"><view class="popup-header data-v-08110e48"><text class="popup-title data-v-08110e48">发起交易意向</text><text class="popup-sub data-v-08110e48">向 {{i}} 报价</text></view><view class="popup-form data-v-08110e48"><view class="form-item data-v-08110e48"><text class="form-label data-v-08110e48">意向单价（元/斤）</text><input class="form-input data-v-08110e48" type="digit" placeholder="请输入意向单价" value="{{j}}" bindinput="{{k}}"/></view><view class="form-item data-v-08110e48"><text class="form-label data-v-08110e48">预计重量（斤）</text><input class="form-input data-v-08110e48" type="number" placeholder="请输入预计重量" value="{{l}}" bindinput="{{m}}"/></view><view class="form-item data-v-08110e48"><text class="form-label data-v-08110e48">期望交接日期</text><picker class="data-v-08110e48" mode="date" value="{{p}}" bindchange="{{q}}"><view class="picker-view data-v-08110e48"><text wx:if="{{n}}" class="data-v-08110e48">{{o}}</text><text wx:else class="picker-placeholder data-v-08110e48">请选择日期</text></view></picker></view></view><view class="popup-actions data-v-08110e48"><button class="pop-cancel data-v-08110e48" bindtap="{{r}}">取消</button><button class="pop-confirm data-v-08110e48" bindtap="{{s}}">提交意向</button></view></view></view>