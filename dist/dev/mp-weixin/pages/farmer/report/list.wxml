<view class="container data-v-672a3bca"><view class="header data-v-672a3bca"><text class="title data-v-672a3bca">📋 申报记录</text><text class="desc data-v-672a3bca">查看您的所有历史申报及处理状态</text></view><view class="stats-bar data-v-672a3bca"><view class="stat-item data-v-672a3bca"><text class="stat-num data-v-672a3bca">{{a}}</text><text class="stat-label data-v-672a3bca">总申报数</text></view><view class="stat-item data-v-672a3bca"><text class="stat-num text-green data-v-672a3bca">{{b}}</text><text class="stat-label data-v-672a3bca">已受理</text></view></view><view class="list-container data-v-672a3bca"><view wx:for="{{c}}" wx:for-item="item" wx:key="l" class="report-card data-v-672a3bca"><view class="card-header data-v-672a3bca"><text class="report-no data-v-672a3bca">单号：{{item.a}}</text><text class="{{['status-badge', 'data-v-672a3bca', item.c]}}">{{item.b}}</text></view><view class="card-body data-v-672a3bca"><view class="info-row data-v-672a3bca"><text class="label data-v-672a3bca">处理日期：</text><text class="value data-v-672a3bca">{{item.d}}</text></view><view class="info-row data-v-672a3bca"><text class="label data-v-672a3bca">预估重量：</text><text class="value highlight data-v-672a3bca">{{item.e}} 斤</text></view><view class="info-row data-v-672a3bca"><text class="label data-v-672a3bca">柑橘品种：</text><text class="value data-v-672a3bca">{{item.f}}</text></view><view class="info-row data-v-672a3bca"><text class="label data-v-672a3bca">处理地点：</text><text class="value address data-v-672a3bca">{{item.g}}</text></view></view><view class="card-footer data-v-672a3bca"><text class="time data-v-672a3bca">{{item.h}}</text><view class="actions data-v-672a3bca"><button class="btn btn-detail data-v-672a3bca" size="mini" bindtap="{{item.i}}">查看详情</button><button wx:if="{{item.j}}" class="btn btn-delete data-v-672a3bca" size="mini" bindtap="{{item.k}}">删除</button></view></view></view><view wx:if="{{d}}" class="empty-state data-v-672a3bca"><text class="empty-icon data-v-672a3bca">📂</text><text class="empty-text data-v-672a3bca">暂无申报记录</text><button class="btn-create data-v-672a3bca" bindtap="{{e}}">去申报</button></view></view></view>