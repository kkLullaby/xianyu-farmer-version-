<view class="container data-v-dd3a9fa7"><view class="header data-v-dd3a9fa7"><text class="title data-v-dd3a9fa7">🌾 处理商需求大厅</text><text class="desc data-v-dd3a9fa7">查看处理商发布的柑橘果肉收购需求</text></view><view class="filter-bar data-v-dd3a9fa7"><view class="{{['filter-item', 'data-v-dd3a9fa7', a && 'active']}}" bindtap="{{b}}"><text class="data-v-dd3a9fa7">全部需求</text></view><view class="{{['filter-item', 'data-v-dd3a9fa7', c && 'active']}}" bindtap="{{d}}"><text class="data-v-dd3a9fa7">提供运输</text></view><view class="{{['filter-item', 'data-v-dd3a9fa7', e && 'active']}}" bindtap="{{f}}"><text class="data-v-dd3a9fa7">高价优先</text></view></view><view class="list-container data-v-dd3a9fa7"><view wx:for="{{g}}" wx:for-item="item" wx:key="i" class="demand-card data-v-dd3a9fa7"><view class="card-header data-v-dd3a9fa7"><text class="buyer-name data-v-dd3a9fa7">{{item.a}}</text><text class="deadline-tag data-v-dd3a9fa7">截止: {{item.b}}</text></view><view class="card-body data-v-dd3a9fa7"><view class="info-row data-v-dd3a9fa7"><text class="label data-v-dd3a9fa7">需求品种：</text><text class="value data-v-dd3a9fa7">{{item.c}}</text></view><view class="info-row data-v-dd3a9fa7"><text class="label data-v-dd3a9fa7">需求重量：</text><text class="value highlight data-v-dd3a9fa7">{{item.d}} 吨</text></view><view class="info-row data-v-dd3a9fa7"><text class="label data-v-dd3a9fa7">收购单价：</text><text class="value price data-v-dd3a9fa7">¥ {{item.e}}/吨</text></view><view class="info-row data-v-dd3a9fa7"><text class="label data-v-dd3a9fa7">运输方式：</text><text wx:if="{{item.f}}" class="value tag-transport data-v-dd3a9fa7">商家自提</text><text wx:else class="value tag-self data-v-dd3a9fa7">农户送货</text></view><view class="info-row description data-v-dd3a9fa7"><text class="label data-v-dd3a9fa7">详细说明：</text><text class="value data-v-dd3a9fa7">{{item.g}}</text></view></view><view class="card-footer data-v-dd3a9fa7"><view class="actions data-v-dd3a9fa7"><button class="btn btn-intention data-v-dd3a9fa7" size="mini" bindtap="{{item.h}}">📨 发起意向</button></view></view></view><view wx:if="{{h}}" class="empty-state data-v-dd3a9fa7"><text class="empty-text data-v-dd3a9fa7">暂无符合条件的收购需求</text></view></view><view wx:if="{{i}}" class="mask data-v-dd3a9fa7" bindtap="{{j}}"></view><view wx:if="{{k}}" class="intention-popup data-v-dd3a9fa7"><view class="popup-header data-v-dd3a9fa7"><text class="popup-title data-v-dd3a9fa7">📨 发起报价意向</text><text class="popup-sub data-v-dd3a9fa7">对象：{{l}}</text></view><view class="popup-body data-v-dd3a9fa7"><view class="popup-row data-v-dd3a9fa7"><text class="popup-label data-v-dd3a9fa7">我的报价（元/吨）</text><input class="popup-input data-v-dd3a9fa7" type="digit" placeholder="请输入您的报价" value="{{m}}" bindinput="{{n}}"/></view><view class="popup-row data-v-dd3a9fa7"><text class="popup-label data-v-dd3a9fa7">预估重量（吨）</text><input class="popup-input data-v-dd3a9fa7" type="digit" placeholder="请输入预估重量" value="{{o}}" bindinput="{{p}}"/></view><view class="popup-row data-v-dd3a9fa7"><text class="popup-label data-v-dd3a9fa7">期望交货日期</text><input class="popup-input data-v-dd3a9fa7" type="text" placeholder="例：2026-03-15" value="{{q}}" bindinput="{{r}}"/></view></view><view class="popup-actions data-v-dd3a9fa7"><button class="btn-pop-cancel data-v-dd3a9fa7" bindtap="{{s}}">取消</button><button class="btn-pop-confirm data-v-dd3a9fa7" bindtap="{{t}}">发送意向</button></view></view></view>