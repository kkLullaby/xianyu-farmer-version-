<view class="container data-v-dd3a9fa7"><view class="header data-v-dd3a9fa7"><text class="title data-v-dd3a9fa7">🌾 处理商求购大厅</text><text class="desc data-v-dd3a9fa7">查看处理商发布的柑橘果肉收购需求</text></view><view class="filter-bar data-v-dd3a9fa7"><view class="{{['filter-item', 'data-v-dd3a9fa7', a && 'active']}}" bindtap="{{b}}"><text class="data-v-dd3a9fa7">全部需求</text></view><view class="{{['filter-item', 'data-v-dd3a9fa7', c && 'active']}}" bindtap="{{d}}"><text class="data-v-dd3a9fa7">提供运输</text></view><view class="{{['filter-item', 'data-v-dd3a9fa7', e && 'active']}}" bindtap="{{f}}"><text class="data-v-dd3a9fa7">高价优先</text></view></view><view class="list-container data-v-dd3a9fa7"><view wx:for="{{g}}" wx:for-item="item" wx:key="j" class="demand-card data-v-dd3a9fa7"><view class="card-header data-v-dd3a9fa7"><text class="buyer-name data-v-dd3a9fa7">{{item.a}}</text><text class="deadline-tag data-v-dd3a9fa7">截止: {{item.b}}</text></view><view class="card-body data-v-dd3a9fa7"><view class="info-row data-v-dd3a9fa7"><text class="label data-v-dd3a9fa7">需求品种：</text><text class="value data-v-dd3a9fa7">{{item.c}}</text></view><view class="info-row data-v-dd3a9fa7"><text class="label data-v-dd3a9fa7">需求重量：</text><text class="value highlight data-v-dd3a9fa7">{{item.d}} 吨</text></view><view class="info-row data-v-dd3a9fa7"><text class="label data-v-dd3a9fa7">收购单价：</text><text class="value price data-v-dd3a9fa7">¥ {{item.e}}/吨</text></view><view class="info-row data-v-dd3a9fa7"><text class="label data-v-dd3a9fa7">运输方式：</text><text wx:if="{{item.f}}" class="value tag-transport data-v-dd3a9fa7">商家自提</text><text wx:else class="value tag-self data-v-dd3a9fa7">农户送货</text></view><view class="info-row description data-v-dd3a9fa7"><text class="label data-v-dd3a9fa7">详细说明：</text><text class="value data-v-dd3a9fa7">{{item.g}}</text></view></view><view class="card-footer data-v-dd3a9fa7"><view class="actions data-v-dd3a9fa7"><button class="btn btn-call data-v-dd3a9fa7" size="mini" bindtap="{{item.h}}">📞 联系买家</button><button class="btn btn-primary data-v-dd3a9fa7" size="mini" bindtap="{{item.i}}">🚀 立即接单</button></view></view></view><view wx:if="{{h}}" class="empty-state data-v-dd3a9fa7"><text class="empty-text data-v-dd3a9fa7">暂无符合条件的求购需求</text></view></view></view>