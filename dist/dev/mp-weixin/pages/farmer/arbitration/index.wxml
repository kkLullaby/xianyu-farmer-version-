<view class="container data-v-aae9f870"><view class="header data-v-aae9f870"><text class="title data-v-aae9f870">⚖️ 仲裁中心</text><text class="desc data-v-aae9f870">农户端 · 提交纠纷申请，跟踪处理进度</text></view><view class="action-bar data-v-aae9f870"><button class="btn-submit data-v-aae9f870" bindtap="{{b}}">{{a}}</button></view><view wx:if="{{c}}" class="form-panel data-v-aae9f870"><view class="form-title data-v-aae9f870"><text class="form-title-text data-v-aae9f870">填写仲裁申请</text></view><view class="form-item data-v-aae9f870"><text class="label data-v-aae9f870">相关订单号</text><input class="input data-v-aae9f870" placeholder="请输入订单编号" value="{{d}}" bindinput="{{e}}"/></view><view class="form-item data-v-aae9f870"><text class="label data-v-aae9f870">纠纷类型</text><view class="picker-box data-v-aae9f870"><picker class="data-v-aae9f870" mode="selector" range="{{g}}" bindchange="{{h}}"><view class="picker-view data-v-aae9f870"><text class="data-v-aae9f870">{{f}}</text><text class="arrow data-v-aae9f870">▼</text></view></picker></view></view><view class="form-item data-v-aae9f870"><text class="label data-v-aae9f870">问题描述</text><block wx:if="{{r0}}"><textarea class="textarea data-v-aae9f870" placeholder="请详细描述争议情况..." value="{{i}}" bindinput="{{j}}"/></block></view><view class="form-actions data-v-aae9f870"><button class="btn-cancel data-v-aae9f870" bindtap="{{k}}">取消</button><button class="btn-confirm data-v-aae9f870" bindtap="{{l}}">确认提交</button></view></view><view class="section-title-row data-v-aae9f870"><text class="section-label data-v-aae9f870">历史仲裁记录</text><text class="section-count data-v-aae9f870">共 {{m}} 条</text></view><view class="list-container data-v-aae9f870"><view wx:for="{{n}}" wx:for-item="item" wx:key="j" class="arb-card data-v-aae9f870"><view class="card-top data-v-aae9f870"><text class="arb-no data-v-aae9f870">{{item.a}}</text><text class="{{['status-badge', 'data-v-aae9f870', item.c]}}">{{item.b}}</text></view><view class="card-body data-v-aae9f870"><view class="info-row data-v-aae9f870"><text class="info-label data-v-aae9f870">相关订单：</text><text class="info-value data-v-aae9f870">{{item.d}}</text></view><view class="info-row data-v-aae9f870"><text class="info-label data-v-aae9f870">纠纷类型：</text><text class="info-value highlight-green data-v-aae9f870">{{item.e}}</text></view><view class="info-row data-v-aae9f870"><text class="info-label data-v-aae9f870">描述：</text><text class="info-value data-v-aae9f870">{{item.f}}</text></view><view wx:if="{{item.g}}" class="info-row data-v-aae9f870"><text class="info-label data-v-aae9f870">裁决结果：</text><text class="info-value result-text data-v-aae9f870">{{item.h}}</text></view></view><view class="card-footer data-v-aae9f870"><text class="time-text data-v-aae9f870">申请时间：{{item.i}}</text></view></view><view wx:if="{{o}}" class="empty-state data-v-aae9f870"><text class="empty-text data-v-aae9f870">暂无仲裁记录</text></view></view></view>