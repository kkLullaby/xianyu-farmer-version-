
.container.data-v-a2d3f174 {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #FAFAF5;
}
.header-section.data-v-a2d3f174 {
  margin-bottom: 20rpx;
}
.page-title.data-v-a2d3f174 {
  font-size: 44rpx;
  font-weight: bold;
  color: #1B3A24;
  display: block;
}
.page-desc.data-v-a2d3f174 {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
  display: block;
}

/* Tab Bar */
.tab-bar.data-v-a2d3f174 {
  display: flex;
  background: #fff;
  padding: 0 40rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}
.tab-item.data-v-a2d3f174 {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  position: relative;
}
.tab-text.data-v-a2d3f174 {
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
}
.tab-item.active .tab-text.data-v-a2d3f174 {
  color: #2E7D32;
  font-weight: bold;
}
.tab-line.data-v-a2d3f174 {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #2E7D32;
  border-radius: 4rpx;
}

/* 列表样式 */
.demands-list.data-v-a2d3f174 {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}
.glass-card.data-v-a2d3f174 {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.05);
  padding: 40rpx;
}
.border-processor.data-v-a2d3f174 { border-left: 8rpx solid #9b59b6;
}
.border-recycler.data-v-a2d3f174 { border-left: 8rpx solid #FF9800;
}
.card-header.data-v-a2d3f174 {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}
.title-row.data-v-a2d3f174 {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}
.source-label.data-v-a2d3f174 {
  color: white;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}
.bg-processor.data-v-a2d3f174 { background-color: #9b59b6;
}
.bg-recycler.data-v-a2d3f174 { background-color: #FF9800;
}
.tag.data-v-a2d3f174 {
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}
.tag-processor.data-v-a2d3f174 { background-color: #f0e6ff; color: #9b59b6;
}
.tag-recycler.data-v-a2d3f174 { background-color: #fff3e0; color: #FF9800;
}
.request-no.data-v-a2d3f174 {
  color: #999;
  font-size: 24rpx;
  display: block;
}
.valid-text.data-v-a2d3f174 {
  font-size: 24rpx;
  color: #999;
}
.long-term.data-v-a2d3f174 { color: #4CAF50;
}
.info-box.data-v-a2d3f174 {
  background-color: #f5f0ff;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}
.info-grid.data-v-a2d3f174 {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.info-item.data-v-a2d3f174 {
  width: 45%;
  font-size: 26rpx;
  display: flex;
  align-items: center;
}
.info-item.full-width.data-v-a2d3f174 { width: 100%;
}
.highlight-processor.data-v-a2d3f174 {
  color: #9b59b6;
  font-weight: bold;
}
.contact-box.data-v-a2d3f174 {
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}
.contact-item.data-v-a2d3f174 {
  font-size: 26rpx;
  margin-bottom: 8rpx;
  display: flex;
}
.label.data-v-a2d3f174 { font-weight: bold; color: #333;
}
.value.data-v-a2d3f174 { color: #333; margin-left: 10rpx;
}
.notes.data-v-a2d3f174 { margin-bottom: 24rpx;
}
.notes-text.data-v-a2d3f174 { color: #666; font-size: 26rpx;
}

/* 价格盒子 */
.price-box.data-v-a2d3f174 {
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}
.price-box-recycler.data-v-a2d3f174 {
  background: #fff8f0;
  border-left: 6rpx solid #FF9800;
}
.price-box-processor.data-v-a2d3f174 {
  background: #f8f0ff;
  border-left: 6rpx solid #9b59b6;
}
.price-row.data-v-a2d3f174 {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.price-label.data-v-a2d3f174 { font-size: 26rpx; color: #666;
}
.price-original.data-v-a2d3f174 { font-size: 26rpx; color: #333;
}
.price-fee.data-v-a2d3f174 { font-size: 26rpx; color: #e74c3c;
}
.price-final.data-v-a2d3f174 {
  font-size: 32rpx;
  color: #FF9800;
  font-weight: bold;
}
.price-final-purple.data-v-a2d3f174 {
  font-size: 32rpx;
  color: #9b59b6;
  font-weight: bold;
}
.price-tip.data-v-a2d3f174 {
  font-size: 22rpx;
  color: #bbb;
  display: block;
  margin-top: 4rpx;
}
.action-row.data-v-a2d3f174 { display: flex; justify-content: flex-end;
}
.action-btn.data-v-a2d3f174 {
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 0 32rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  font-weight: bold;
  margin: 0;
}
.btn-processor.data-v-a2d3f174 { background-color: #9b59b6;
}
.btn-recycler.data-v-a2d3f174 { background-color: #FF9800;
}
