<view class="container data-v-a12bd353"><view class="header data-v-a12bd353"><text class="title data-v-a12bd353">📍 我的地址</text><text class="desc data-v-a12bd353">管理您的收发货与果园/厂区地址</text></view><view class="address-list data-v-a12bd353"><view wx:for="{{a}}" wx:for-item="item" wx:key="k" class="address-card data-v-a12bd353"><view class="card-top-row data-v-a12bd353"><view class="contact-row data-v-a12bd353"><text class="contact-name data-v-a12bd353">{{item.a}}</text><text class="contact-phone data-v-a12bd353">{{item.b}}</text><text wx:if="{{item.c}}" class="default-badge data-v-a12bd353">默认</text></view><text wx:if="{{item.d}}" class="public-badge public-on data-v-a12bd353">👁️ 已公开展示</text><text wx:else class="public-badge public-off data-v-a12bd353">🔒 仅自己可见</text></view><view class="address-detail data-v-a12bd353"><text class="region-text data-v-a12bd353">{{item.e}}</text><text class="detail-text data-v-a12bd353">{{item.f}}</text></view><view class="card-actions data-v-a12bd353"><view class="action-btn data-v-a12bd353" bindtap="{{item.g}}"><text class="action-text data-v-a12bd353">✏️ 编辑</text></view><view wx:if="{{item.h}}" class="action-btn data-v-a12bd353" bindtap="{{item.i}}"><text class="action-text data-v-a12bd353">⭐ 设为默认</text></view><view class="action-btn action-delete data-v-a12bd353" bindtap="{{item.j}}"><text class="action-text-red data-v-a12bd353">🗑️ 删除</text></view></view></view><view wx:if="{{b}}" class="empty-state data-v-a12bd353"><text class="empty-icon data-v-a12bd353">📭</text><text class="empty-text data-v-a12bd353">暂无地址，快去添加吧</text></view></view><view class="bottom-bar data-v-a12bd353"><button class="add-btn data-v-a12bd353" bindtap="{{c}}">+ 新增收货地址</button></view></view>