
/* --- 全局统一工作台样式 --- */
.container.data-v-60f6a030 {
  padding: 40rpx;
  min-height: 100vh;
  background-color: #FAFAF5;
}
.header.data-v-60f6a030 {
  margin-bottom: 60rpx;
}
.title.data-v-60f6a030 {
  font-size: 48rpx;
  font-weight: bold;
  color: #1B3A24;
  display: block;
  margin-bottom: 10rpx;
}
.subtitle.data-v-60f6a030 {
  font-size: 32rpx;
  color: #1565C0;
  display: block;
  margin-bottom: 10rpx;
}
.desc.data-v-60f6a030 {
  font-size: 26rpx;
  color: #45664E;
}
.section.data-v-60f6a030 {
  margin-bottom: 50rpx;
}
.section-header.data-v-60f6a030 {
  margin-bottom: 30rpx;
  border-bottom: 2rpx solid rgba(0,0,0,0.05);
  padding-bottom: 20rpx;
}
.section-title.data-v-60f6a030 {
  font-size: 34rpx;
  font-weight: bold;
  color: #1B3A24;
}
.card-grid.data-v-60f6a030 {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.card.data-v-60f6a030 {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04);
  border-left: 10rpx solid #eee;
  transition: transform 0.2s;
}
.card.data-v-60f6a030:active {
  transform: scale(0.98);
}
.card-title.data-v-60f6a030 {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 12rpx;
}
.card-desc.data-v-60f6a030 {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

