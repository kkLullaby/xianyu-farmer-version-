<view class="container data-v-c851e281"><view class="header data-v-c851e281"><text class="title data-v-c851e281">🌾 货源供应</text><text class="desc data-v-c851e281">对接农户与回收商货源，查看供应信息并进行采购</text></view><view class="filter-bar data-v-c851e281"><view class="{{['filter-item', 'data-v-c851e281', a && 'active']}}" bindtap="{{b}}"><text class="data-v-c851e281">全部货源</text></view><view class="{{['filter-item', 'data-v-c851e281', c && 'active']}}" bindtap="{{d}}"><text class="data-v-c851e281">农户直供</text></view><view class="{{['filter-item', 'data-v-c851e281', e && 'active']}}" bindtap="{{f}}"><text class="data-v-c851e281">回收商转供</text></view></view><view class="list-container data-v-c851e281"><view wx:for="{{g}}" wx:for-item="item" wx:key="j" class="supply-card data-v-c851e281"><view class="card-header data-v-c851e281"><text class="{{['supply-type', 'data-v-c851e281', item.b]}}">{{item.a}}</text><text class="variety data-v-c851e281">{{item.c}}</text></view><view class="card-body data-v-c851e281"><view class="info-row data-v-c851e281"><text class="label data-v-c851e281">供应商：</text><text class="value data-v-c851e281">{{item.d}}</text></view><view class="info-row data-v-c851e281"><text class="label data-v-c851e281">可供重量：</text><text class="value highlight data-v-c851e281">{{item.e}} 斤</text></view><view class="info-row data-v-c851e281"><text class="label data-v-c851e281">期望单价：</text><text class="value price data-v-c851e281">¥ {{item.f}}/斤</text></view><view class="info-row data-v-c851e281"><text class="label data-v-c851e281">所在地：</text><text class="value address data-v-c851e281">{{item.g}}</text></view></view><view class="card-footer data-v-c851e281"><text class="time data-v-c851e281">发布于 {{item.h}}</text><view class="actions data-v-c851e281"><button class="btn btn-primary data-v-c851e281" size="mini" bindtap="{{item.i}}">发起意向</button></view></view></view><view wx:if="{{h}}" class="empty-state data-v-c851e281"><text class="empty-text data-v-c851e281">暂无符合条件的货源</text></view></view><view wx:if="{{i}}" class="popup-mask data-v-c851e281" bindtap="{{j}}"></view><view wx:if="{{k}}" class="intention-popup data-v-c851e281"><view class="popup-header data-v-c851e281"><text class="popup-title data-v-c851e281">发起采购意向</text><text class="popup-sub data-v-c851e281">向 {{l}} 发起意向报价</text></view><view class="popup-form data-v-c851e281"><view class="form-item data-v-c851e281"><text class="form-label data-v-c851e281">意向单价（元/斤）</text><input class="form-input data-v-c851e281" type="digit" placeholder="请输入你的报价" value="{{m}}" bindinput="{{n}}"/></view><view class="form-item data-v-c851e281"><text class="form-label data-v-c851e281">预计采购重量（斤）</text><input class="form-input data-v-c851e281" type="number" placeholder="请输入预计重量" value="{{o}}" bindinput="{{p}}"/></view><view class="form-item data-v-c851e281"><text class="form-label data-v-c851e281">期望交接日期</text><picker class="data-v-c851e281" mode="date" value="{{s}}" bindchange="{{t}}"><view class="picker-view data-v-c851e281"><text wx:if="{{q}}" class="data-v-c851e281">{{r}}</text><text wx:else class="picker-placeholder data-v-c851e281">请选择日期</text></view></picker></view></view><view class="popup-actions data-v-c851e281"><button class="pop-cancel data-v-c851e281" bindtap="{{v}}">取消</button><button class="pop-confirm data-v-c851e281" bindtap="{{w}}">提交意向</button></view></view></view>