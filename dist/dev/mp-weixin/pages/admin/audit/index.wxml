<view class="container data-v-ea810333"><view class="header data-v-ea810333"><text class="title data-v-ea810333">📋 申报审核</text><text class="desc data-v-ea810333">审核各角色发布的交易/求购单据，设置平台抽成</text></view><view class="tab-bar data-v-ea810333"><view class="{{['tab-item', 'data-v-ea810333', b && 'active']}}" bindtap="{{c}}"><text class="tab-text data-v-ea810333">农户申报</text><view wx:if="{{a}}" class="tab-line data-v-ea810333"></view></view><view class="{{['tab-item', 'data-v-ea810333', e && 'active']}}" bindtap="{{f}}"><text class="tab-text data-v-ea810333">回收商发布</text><view wx:if="{{d}}" class="tab-line data-v-ea810333"></view></view><view class="{{['tab-item', 'data-v-ea810333', h && 'active']}}" bindtap="{{i}}"><text class="tab-text data-v-ea810333">处理商发布</text><view wx:if="{{g}}" class="tab-line data-v-ea810333"></view></view></view><view class="stats-row data-v-ea810333"><text class="stats-text data-v-ea810333">当前待审核：{{j}} 条</text></view><view class="list-container data-v-ea810333"><view wx:for="{{k}}" wx:for-item="item" wx:key="w" class="{{['audit-card', 'data-v-ea810333', item.v && 'card-approved']}}"><view class="card-top data-v-ea810333"><text class="card-no data-v-ea810333">{{item.a}}</text><text class="{{['audit-badge', 'data-v-ea810333', item.c]}}">{{item.b}}</text></view><view class="card-body data-v-ea810333"><view class="info-row data-v-ea810333"><text class="label data-v-ea810333">提交人：</text><text class="val data-v-ea810333">{{item.d}} ({{item.e}})</text></view><view class="info-row data-v-ea810333"><text class="label data-v-ea810333">类型：</text><text class="val highlight data-v-ea810333">{{item.f}}</text></view><view class="info-row data-v-ea810333"><text class="label data-v-ea810333">品种/规格：</text><text class="val data-v-ea810333">{{item.g}}</text></view><view class="info-row data-v-ea810333"><text class="label data-v-ea810333">数量：</text><text class="val data-v-ea810333">{{item.h}}</text></view><view class="info-row data-v-ea810333"><text class="label data-v-ea810333">申报单价：</text><text class="val price-text data-v-ea810333">{{item.i}} 元/斤</text></view><view wx:if="{{item.j}}" class="info-row data-v-ea810333"><text class="label data-v-ea810333">抽成设定：</text><text class="val text-blue data-v-ea810333">{{item.k}}</text></view><view wx:if="{{item.l}}" class="info-row data-v-ea810333"><text class="label data-v-ea810333">实际到手：</text><text class="val text-green data-v-ea810333">{{item.m}} 元/斤</text></view></view><view class="card-bottom data-v-ea810333"><text class="time-text data-v-ea810333">提交时间：{{item.n}}</text><view class="btn-group data-v-ea810333"><button wx:if="{{item.o}}" class="btn-audit data-v-ea810333" bindtap="{{item.p}}">审批</button><button wx:if="{{item.q}}" class="btn-reject data-v-ea810333" bindtap="{{item.r}}">驳回</button><text wx:if="{{item.s}}" class="approved-tag data-v-ea810333">✅ 已通过</text><text wx:if="{{item.t}}" class="rejected-tag data-v-ea810333">❌ 已驳回</text></view></view></view><view wx:if="{{l}}" class="empty-state data-v-ea810333"><text class="empty-text data-v-ea810333">暂无审核数据</text></view></view><view wx:if="{{m}}" class="mask data-v-ea810333" bindtap="{{n}}"></view><view wx:if="{{o}}" class="commission-popup data-v-ea810333"><view class="popup-header data-v-ea810333"><text class="popup-title data-v-ea810333">💰 设置平台抽成</text><text class="popup-sub data-v-ea810333">单据：{{p}} · {{q}}</text></view><view class="popup-info data-v-ea810333"><view class="popup-info-row data-v-ea810333"><text class="popup-info-label data-v-ea810333">申报单价：</text><text class="popup-info-value data-v-ea810333">{{r}} 元/斤</text></view><view class="popup-info-row data-v-ea810333"><text class="popup-info-label data-v-ea810333">申报数量：</text><text class="popup-info-value data-v-ea810333">{{s}}</text></view></view><view class="popup-section data-v-ea810333"><text class="popup-label data-v-ea810333">抽成方式</text><view class="type-selector data-v-ea810333"><view class="{{['type-option', 'data-v-ea810333', t && 'type-active']}}" bindtap="{{v}}"><text class="type-text data-v-ea810333">比例抽成 (%)</text></view><view class="{{['type-option', 'data-v-ea810333', w && 'type-active']}}" bindtap="{{x}}"><text class="type-text data-v-ea810333">固定金额 (¥)</text></view></view></view><view class="popup-section data-v-ea810333"><text class="popup-label data-v-ea810333">{{y}}</text><input class="popup-input data-v-ea810333" type="digit" placeholder="{{z}}" value="{{A}}" bindinput="{{B}}"/></view><view wx:if="{{C}}" class="popup-preview data-v-ea810333"><text class="preview-label data-v-ea810333">预览计算：</text><text wx:if="{{D}}" class="preview-formula data-v-ea810333">{{E}} × (1 - {{F}}%) = {{G}} 元/斤（卖方到手） </text><text wx:else class="preview-formula data-v-ea810333">{{H}} - {{I}} = {{J}} 元/斤（卖方到手） </text></view><view class="popup-actions data-v-ea810333"><button class="btn-pop-cancel data-v-ea810333" bindtap="{{K}}">取消</button><button class="btn-pop-confirm data-v-ea810333" bindtap="{{L}}">通过审核</button></view></view></view>