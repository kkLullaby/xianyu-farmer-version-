
.container.data-v-ea810333 {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #FAFAF5;
}
.header.data-v-ea810333 { margin-bottom: 30rpx;
}
.title.data-v-ea810333 {
  font-size: 40rpx;
  font-weight: bold;
  color: #1B3A24;
  display: block;
  margin-bottom: 10rpx;
}
.desc.data-v-ea810333 { font-size: 26rpx; color: #45664E;
}
.tab-bar.data-v-ea810333 {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}
.tab-item.data-v-ea810333 {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  position: relative;
}
.tab-text.data-v-ea810333 { font-size: 28rpx; color: #666; font-weight: 500;
}
.tab-item.active .tab-text.data-v-ea810333 { color: #1565C0; font-weight: bold;
}
.tab-line.data-v-ea810333 {
  position: absolute;
  bottom: 0; left: 50%; transform: translateX(-50%);
  width: 40rpx; height: 6rpx;
  background: #1565C0; border-radius: 4rpx;
}
.stats-row.data-v-ea810333 {
  margin-bottom: 20rpx;
}
.stats-text.data-v-ea810333 { font-size: 26rpx; color: #999;
}
.list-container.data-v-ea810333 {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.audit-card.data-v-ea810333 {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  border-left: 8rpx solid #EF6C00;
}
.card-approved.data-v-ea810333 { border-left-color: #2E7D32;
}
.card-top.data-v-ea810333 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.card-no.data-v-ea810333 { font-size: 26rpx; color: #999;
}
.audit-badge.data-v-ea810333 {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  font-weight: bold;
}
.audit-pending.data-v-ea810333 { background: #FFF3E0; color: #EF6C00;
}
.audit-approved.data-v-ea810333 { background: #e8f5e9; color: #2E7D32;
}
.audit-rejected.data-v-ea810333 { background: #fce4ec; color: #c62828;
}
.card-body.data-v-ea810333 { margin-bottom: 16rpx;
}
.info-row.data-v-ea810333 {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 27rpx;
}
.label.data-v-ea810333 { color: #888; width: 170rpx;
}
.val.data-v-ea810333 { color: #333; flex: 1;
}
.highlight.data-v-ea810333 { color: #1565C0; font-weight: bold;
}
.price-text.data-v-ea810333 { color: #e74c3c; font-weight: bold;
}
.text-blue.data-v-ea810333 { color: #1565C0; font-weight: bold;
}
.text-green.data-v-ea810333 { color: #2E7D32; font-weight: bold;
}
.card-bottom.data-v-ea810333 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx dashed #eee;
}
.time-text.data-v-ea810333 { font-size: 24rpx; color: #bbb;
}
.btn-group.data-v-ea810333 { display: flex; gap: 12rpx;
}
.btn-audit.data-v-ea810333 {
  background: #1565C0;
  color: white;
  font-size: 24rpx;
  padding: 0 28rpx;
  border-radius: 30rpx;
  height: 56rpx;
  line-height: 56rpx;
  margin: 0;
  border: none;
}
.btn-reject.data-v-ea810333 {
  background: #fff;
  color: #c62828;
  font-size: 24rpx;
  padding: 0 28rpx;
  border-radius: 30rpx;
  height: 56rpx;
  line-height: 56rpx;
  border: 2rpx solid #c62828;
  margin: 0;
}
.approved-tag.data-v-ea810333 { font-size: 24rpx; color: #2E7D32;
}
.rejected-tag.data-v-ea810333 { font-size: 24rpx; color: #c62828;
}
.empty-state.data-v-ea810333 { text-align: center; padding: 80rpx 0;
}
.empty-text.data-v-ea810333 { font-size: 28rpx; color: #bbb;
}

/* --- 抽成弹窗 --- */
.mask.data-v-ea810333 {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 998;
}
.commission-popup.data-v-ea810333 {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: white;
  border-radius: 40rpx 40rpx 0 0;
  padding: 50rpx 40rpx;
  z-index: 999;
  max-height: 85vh;
  overflow-y: auto;
  box-shadow: 0 -8rpx 40rpx rgba(0,0,0,0.12);
}
.popup-header.data-v-ea810333 { margin-bottom: 30rpx;
}
.popup-title.data-v-ea810333 {
  font-size: 36rpx;
  font-weight: bold;
  color: #1B3A24;
  display: block;
  margin-bottom: 8rpx;
}
.popup-sub.data-v-ea810333 { font-size: 26rpx; color: #999;
}
.popup-info.data-v-ea810333 {
  background: #f9f9f9;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}
.popup-info-row.data-v-ea810333 {
  display: flex;
  margin-bottom: 8rpx;
  font-size: 27rpx;
}
.popup-info-label.data-v-ea810333 { color: #888; width: 170rpx;
}
.popup-info-value.data-v-ea810333 { color: #333; font-weight: bold;
}
.popup-section.data-v-ea810333 { margin-bottom: 30rpx;
}
.popup-label.data-v-ea810333 {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}
.type-selector.data-v-ea810333 { display: flex; gap: 16rpx;
}
.type-option.data-v-ea810333 {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  background: #fafafa;
}
.type-active.data-v-ea810333 { border-color: #1565C0; background: #e3f2fd;
}
.type-text.data-v-ea810333 { font-size: 26rpx; color: #333;
}
.type-active .type-text.data-v-ea810333 { color: #1565C0; font-weight: bold;
}
.popup-input.data-v-ea810333 {
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
}
.popup-preview.data-v-ea810333 {
  background: #f5f0ff;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  border-left: 6rpx solid #1565C0;
}
.preview-label.data-v-ea810333 {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-bottom: 8rpx;
}
.preview-formula.data-v-ea810333 { font-size: 26rpx; color: #1565C0; font-weight: bold;
}
.popup-actions.data-v-ea810333 { display: flex; gap: 20rpx;
}
.btn-pop-cancel.data-v-ea810333 {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 12rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  margin: 0;
}
.btn-pop-confirm.data-v-ea810333 {
  flex: 2;
  background: #1565C0;
  color: white;
  border: none;
  border-radius: 12rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin: 0;
}
